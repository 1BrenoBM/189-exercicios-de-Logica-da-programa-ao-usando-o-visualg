Algoritmo "HorasParaMinutos"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Converte horas em minutos
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   h: inteiro

Inicio
   escreval("Digite horas:")
   leia(h)

   escreva(h * 60)
Fimalgoritmo