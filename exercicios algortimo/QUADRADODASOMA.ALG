Algoritmo "QuadradoDaSoma"
// Disciplina   : linguagem de programaÓÐo com o Visual G
// Professor   : Jailson
// DescriÓÐo   : Calcula o quadrado da soma de dois nºmeros
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,res: real

Inicio
   escreval("Digite dois numeros:")
   leia(a,b)

   res <- (a+b)*(a+b)

   escreva(res)
Fimalgoritmo