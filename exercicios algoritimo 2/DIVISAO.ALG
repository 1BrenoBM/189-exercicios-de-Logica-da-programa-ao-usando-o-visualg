AAlgoritmo "Divisao"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Divide dois valores
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,res: real

Inicio
Escreval("Digite numero para dividir")
   leia(a,b)
   res <- a / b
   escreva(res)
Fimalgoritmo