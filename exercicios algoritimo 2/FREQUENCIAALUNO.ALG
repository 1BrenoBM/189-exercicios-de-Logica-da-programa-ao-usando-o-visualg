Algoritmo "FrequenciaAluno"
// Disciplina   : linguagem de programańŃo com o Visual G
// Professor   : Jailson
// DescrińŃo   : Verifica faltas
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   faltas: inteiro

Inicio
   escreval("Digite numero de faltas:")
   leia(faltas)

   se faltas > 15 entao
      escreva("Reprovado por faltas")
   senao
      escreva("Frequencia dentro do limite")
   fimse
Fimalgoritmo