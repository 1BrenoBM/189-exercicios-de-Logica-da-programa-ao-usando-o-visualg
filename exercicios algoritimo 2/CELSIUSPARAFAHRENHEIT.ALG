Algoritmo "CelsiusParaFahrenheit"
// Disciplina   : linguagem de programaÓÐo com o Visual G
// Professor   : Jailson
// DescriÓÐo   : Converte temperatura
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   c,f: real

Inicio
   escreval("Digite temperatura em Celsius:")
   leia(c)

   f <- (9*c + 160)/5

   escreva(f)
Fimalgoritmo