Algoritmo "CelsiusParaKelvin"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Converte Celsius para Kelvin
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   c,k: real

Inicio
   escreval("Digite temperatura em Celsius:")
   leia(c)

   k <- c + 273

   escreva(k)
Fimalgoritmo