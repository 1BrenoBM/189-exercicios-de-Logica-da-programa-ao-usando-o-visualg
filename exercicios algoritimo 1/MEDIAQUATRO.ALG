Algoritmo "MediaQuatro"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula média de quatro valores
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,c,d,media: real

Inicio
escreval("escreva quatro numeros para fazer a media")
   leia(a,b,c,d)

   media <- (a+b+c+d)/4

   escreva(media)
Fimalgoritmo