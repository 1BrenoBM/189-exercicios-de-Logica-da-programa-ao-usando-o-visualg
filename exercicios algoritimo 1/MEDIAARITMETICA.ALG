Algoritmo "MediaAritmetica"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula média de três valores
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,c,media: real

Inicio
   escreval("Digite tres numeros:")
   leia(a,b,c)

   media <- (a+b+c)/3

   escreva(media)
Fimalgoritmo