Algoritmo "DobroNumero"
// Disciplina   : linguagem de programaÓÐo com o Visual G
// Professor   : Jailson
// DescriÓÐo   : Calcula o dobro
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   n: real

Inicio
   escreval("Digite um numero:")
   leia(n)

   escreva(n*2)
Fimalgoritmo