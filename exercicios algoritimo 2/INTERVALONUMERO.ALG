Algoritmo "IntervaloNumero"
// Disciplina   : linguagem de programańŃo com o Visual G
// Professor   : Jailson
// DescrińŃo   : Verifica se n·mero estß entre 10 e 20
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   n: inteiro

Inicio
   Escreval("Digite numero")
   leia(n)

   se n >= 10 e n <= 20 entao
      escreva("Dentro do intervalo")
   senao
      escreva("Fora do intervalo")
   fimse
Fimalgoritmo