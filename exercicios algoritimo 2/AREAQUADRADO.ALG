Algoritmo "AreaQuadrado"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula área do quadrado
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   lado,area: real

Inicio
   escreval("Digite o lado:")
   leia(lado)

   area <- lado * lado

   escreva(area)
Fimalgoritmo