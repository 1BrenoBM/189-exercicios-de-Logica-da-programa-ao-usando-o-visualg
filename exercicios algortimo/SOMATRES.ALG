Algoritmo "SomaTres"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Soma três valores
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,c,soma: real

Inicio
   escreval("Digite tres numeros:")
   leia(a,b,c)

   soma <- a + b + c

   escreva(soma)
Fimalgoritmo