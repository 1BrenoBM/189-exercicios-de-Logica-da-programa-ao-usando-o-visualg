Algoritmo "Diferenca"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula diferença entre dois números
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b: real

Inicio
   escreval("Digite dois numeros:")
   leia(a,b)

   escreva(a - b)
Fimalgoritmo