Algoritmo "HorasEstudo"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Verifica excesso de estudo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   horas: inteiro

Inicio
   escreval("Digite horas estudadas:")
   leia(horas)

   se horas > 10 entao
      escreva("Aviso: Necessario descanso")
   fimse
Fimalgoritmo