Algoritmo "MediaDois"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula média de dois valores
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,media: real

Inicio
Escreval("Iserir dois numeros para fazer a media")
   leia(a,b)
   media <- (a+b)/2
   escreva(media)
Fimalgoritmo