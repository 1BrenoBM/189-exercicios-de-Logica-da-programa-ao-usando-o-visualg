Algoritmo "VolumeCaixa"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula volume de uma caixa
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   c,l,a,volume: real

Inicio
   escreval("Digite comprimento, largura e altura:")
   leia(c,l,a)

   volume <- c * l * a

   escreva(volume)
Fimalgoritmo