Algoritmo "AreaCirculo"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula área do círculo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   r,area: real

Inicio
   escreval("Digite o raio:")
   leia(r)

   area <- 3.14 * r * r

   escreva(area)
Fimalgoritmo
