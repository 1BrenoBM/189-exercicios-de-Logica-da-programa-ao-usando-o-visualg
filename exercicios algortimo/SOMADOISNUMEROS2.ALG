AAlgoritmo "SomaDoisNumeros"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Soma dois números informados
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   n1,n2,soma: inteiro

Inicio
   escreval("Digite dois numeros:")
   leia(n1,n2)

   soma <- n1 + n2

   escreva(soma)
Fimalgoritmo