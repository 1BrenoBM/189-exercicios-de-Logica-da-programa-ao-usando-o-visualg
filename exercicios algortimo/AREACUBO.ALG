Algoritmo "AreaCubo"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula área total do cubo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   aresta,area: real

Inicio
   escreval("Digite a aresta do cubo:")
   leia(aresta)

   area <- 6 * aresta * aresta

   escreva(area)
Fimalgoritmo