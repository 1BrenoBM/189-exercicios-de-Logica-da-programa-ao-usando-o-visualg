Algoritmo "AreaParalelogramo"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula área do paralelogramo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   base,altura,area: real

Inicio
   escreval("Digite base e altura:")
   leia(base,altura)

   area <- base * altura

   escreva(area)
Fimalgoritmo