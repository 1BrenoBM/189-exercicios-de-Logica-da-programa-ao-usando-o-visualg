Algoritmo "CalculoDeVolumeCilindro"
// Disciplina  : Lógica de Programaçăo com Visual G
// Professor   :   Jailson
// Descriçăo   :  Produto que faz o calculo de volume do cilindro
// Autor(a)    : Breno
// Data atual  :19/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   raio, altura, Volume: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreva("Qual é a altura da lata em centímetros? ")
   leia(altura)
   Escreva("Qual é o raio da lata em centímetros? ")
   leia(raio)
   volume <- pi * (raio^2) * altura

   Escreva("Essa lata possui capacidade para",volume:0:2,"mL.")

Fimalgoritmo