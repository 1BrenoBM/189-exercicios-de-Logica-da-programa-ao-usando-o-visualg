Algoritmo "AnosParaDias"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Converte anos em dias
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   anos: inteiro

Inicio
   escreval("Digite anos:")
   leia(anos)

   escreva(anos * 365)
Fimalgoritmo