Algoritmo "ConsumoMedio"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula consumo de combustível
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   km,litros,consumo: real

Inicio
   escreval("Digite km percorridos e litros:")
   leia(km,litros)

   consumo <- km / litros

   escreva(consumo)
Fimalgoritmo