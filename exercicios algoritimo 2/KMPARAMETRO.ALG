Algoritmo "KmParaMetro"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Converte km para metros
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   km: real

Inicio
   escreval("Digite valor em km:")
   leia(km)

   escreva(km*1000)
Fimalgoritmo