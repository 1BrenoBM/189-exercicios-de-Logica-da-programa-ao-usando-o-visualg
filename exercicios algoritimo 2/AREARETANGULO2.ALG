Algoritmo "AreaRetangulo"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula área do retângulo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   base,altura,area: real

Inicio
   escreval("Digite base e altura:")
   leia(base,altura)

   area <- base * altura

   escreva(area)
Fimalgoritmo