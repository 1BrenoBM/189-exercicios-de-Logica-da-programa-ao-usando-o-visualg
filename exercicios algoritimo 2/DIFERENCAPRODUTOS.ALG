Algoritmo "DiferencaProdutos"
// Disciplina   : linguagem de programaÓÐo com o Visual G
// Professor   : Jailson
// DescriÓÐo   : Calcula diferenÓa entre produtos
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   a,b,c,d,res: real

Inicio
   escreval("Digite quatro numeros:")
   leia(a,b,c,d)

   res <- (a*b) - (c*d)

   escreva(res)
Fimalgoritmo