Algoritmo "CuboNumero"
// Disciplina   : linguagem de programaēćo com o Visual G
// Professor   : Jailson
// Descriēćo   : Calcula o cubo de um nśmero
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   n,res: real

Inicio
   escreval("Digite um numero:")
   leia(n)

   res <- n * n * n

   escreva(res)
Fimalgoritmo