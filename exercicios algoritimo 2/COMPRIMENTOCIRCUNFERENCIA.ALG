Algoritmo "ComprimentoCircunferencia"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula comprimento da circunferęncia
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   r: real

Inicio
   escreval("Digite o raio:")
   leia(r)

   escreva(2 * 3.14 * r)
Fimalgoritmo