Algoritmo "DiasParaHoras"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Converte dias em horas
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   dias: inteiro

Inicio
   escreval("Digite quantidade de dias:")
   leia(dias)

   escreva(dias * 24)
Fimalgoritmo