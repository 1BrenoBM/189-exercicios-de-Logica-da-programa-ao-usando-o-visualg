Algoritmo "AreaLosango"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Calcula área do losango
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   d1,d2,area: real

Inicio
   escreval("Digite as diagonais:")
   leia(d1,d2)

   area <- (d1 * d2)/2

   escreva(area)
Fimalgoritmo