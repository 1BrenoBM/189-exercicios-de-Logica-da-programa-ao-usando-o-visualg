Algoritmo "KelvinParaCelsius"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Converte Kelvin para Celsius
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   k,c: real

Inicio
   escreval("Digite temperatura em Kelvin:")
   leia(k)

   c <- k - 273

   escreva(c)
Fimalgoritmo