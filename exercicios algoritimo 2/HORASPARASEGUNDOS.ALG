Algoritmo "HorasParaSegundos"
// Disciplina   : linguagem de programaçăo com o Visual G
// Professor   : Jailson
// Descriçăo   : Converte horas em segundos
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   h: inteiro

Inicio
   escreval("Digite horas:")
   leia(h)

   escreva(h * 3600)
Fimalgoritmo