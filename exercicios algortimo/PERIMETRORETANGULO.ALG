Algoritmo "PerimetroRetangulo"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Calcula perímetro do retângulo
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   base,altura: real

Inicio
   escreval("Digite base e altura:")
   leia(base,altura)

   escreva(2 * (base + altura))
Fimalgoritmo