AAlgoritmo "AntecessorSucessor"
// Disciplina   : linguagem de programação com o Visual G
// Professor   : Jailson
// Descrição   : Mostra antecessor e sucessor
// Autor(a)    : Breno B.
// Data atual  : 20/04/2026

Var
   n: inteiro

Inicio
   escreval("Digite um numero:")
   leia(n)

   escreva("Antecessor: ", n-1)
   escreva("Sucessor: ", n+1)
Fimalgoritmo